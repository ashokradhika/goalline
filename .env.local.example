# Copy this file to .env.local and fill in the values below.

# AI features (match summaries, team form blurbs, Ask GoalLine chat).
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Live World Cup data (standings, fixtures, scorers).
# Get a free key at https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=

# Predictions tab vote storage (Vercel Redis/KV, or Upstash directly).
# Create one from your Vercel project's Storage tab, then copy the values
# from its ".env.local" tab here. Either naming below works.
KV_REST_API_URL=
KV_REST_API_TOKEN=
